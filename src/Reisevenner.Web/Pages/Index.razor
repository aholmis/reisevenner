@page "/"
@using Reisevenner.Web.Data

@inject NavigationManager Navigation

<div class="home-container">
    <div class="hero">
        <span class="hero-emoji">🚗</span>
        <h1>@Constants.AppName</h1>
        <p class="hero-tagline">Planlegg samkjøring til bursdager, idrettsarrangementer og andre turer. Gjør en innsats for miljøet – sammen!</p>
    </div>

    <div class="home-actions">
        <div class="home-card">
            <span class="home-card-icon">✨</span>
            <h2>Lag et nytt oppdrag</h2>
            <p>Opprett et samkjøringsoppdrag og del koden med venner og familie.</p>
            <button @onclick="CreateNewEvent">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="8" x2="12" y2="16"></line>
                    <line x1="8" y1="12" x2="16" y2="12"></line>
                </svg>
                Lag nytt oppdrag
            </button>
        </div>

        <div class="home-divider"><span>eller</span></div>

        <div class="home-card">
            <span class="home-card-icon">🔑</span>
            <h2>Bli med på et oppdrag</h2>
            <p>Har du en invitasjonskode? Skriv den inn for å åpne oppdraget.</p>
            <div class="join-form">
                <input id="eventcode"
                       type="text"
                       placeholder="Skriv inn kode"
                       @bind="eventcode"
                       @bind:event="oninput"
                       @onkeyup="HandleKeyUp"
                       autocomplete="off"
                       autocorrect="off"
                       autocapitalize="none"
                       spellcheck="false" />
                <button class="join-btn" @onclick="JoinExistingEvent">Åpne</button>
            </div>
        </div>
    </div>
</div>

@code {
    string eventcode = string.Empty;
    string eventPath => "event/" + eventcode;

    void CreateNewEvent()
    {
        Navigation.NavigateTo("/create-event");
    }

    void JoinExistingEvent()
    {
        if (!string.IsNullOrWhiteSpace(eventcode))
            Navigation.NavigateTo(eventPath, true);
    }

    void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            JoinExistingEvent();
    }
}
