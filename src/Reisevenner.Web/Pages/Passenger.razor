<div class="passenger-item">
    <div class="passenger-row">
        <div class="passenger-fields">
            <div class="form-group">
                <label for="passengerName-@PassengerInfo.Id">Navn</label>
                <input id="passengerName-@PassengerInfo.Id" type="text" @bind="PassengerInfo.Name" placeholder="Passasjer navn" />
            </div>
            <div class="form-group">
                <label for="passengerPhone-@PassengerInfo.Id">Telefon eller kommentar</label>
                <input id="passengerPhone-@PassengerInfo.Id" type="text" @bind="PassengerInfo.PhoneOrComment" placeholder="Telefon eller kommentar" />
            </div>
        </div>
        <button class="delete-passenger-btn" @onclick="() => OnDelete.InvokeAsync(PassengerInfo)" title="Fjern passasjer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter]
    public Data.PassengerModel PassengerInfo { get; set; }

    [Parameter]
    public EventCallback<Data.PassengerModel> OnDelete { get; set; }
}
