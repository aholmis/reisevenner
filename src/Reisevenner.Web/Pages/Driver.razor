@using Reisevenner.Web.Data
@inject IJSRuntime JSRuntime

<div class="driver">
    <div class="driver-card-header">
        <span class="driver-badge">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="1" y="3" width="15" height="13" rx="2"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
            </svg>
            Sjåfør
        </span>
        <button class="delete-driver-btn" @onclick="() => OnDelete.InvokeAsync(DriverInfo)" title="Fjern sjåfør">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            </svg>
            Kan ikke kjøre likevel
        </button>
    </div>

    <div class="driver-fields">
        <div class="form-group">
            <label for="Name-@DriverInfo.Id">Navn</label>
            <input id="Name-@DriverInfo.Id" type="text" @bind="DriverInfo.DriverName" placeholder="Ditt navn" />
        </div>
        <div class="form-group">
            <label for="Phone-@DriverInfo.Id">Mobilnr</label>
            <input id="Phone-@DriverInfo.Id" type="text" @bind="DriverInfo.Phone" placeholder="Telefonnummer" />
        </div>
        <div class="form-group driver-fields-full">
            <label for="MeetingPlace-@DriverInfo.Id">Oppmøte (tid og sted)</label>
            <input id="MeetingPlace-@DriverInfo.Id" type="text" @bind="DriverInfo.MeetingPlace" placeholder="F.eks. 12:00 utenfor i veien" />
        </div>
        <div class="form-group">
            <label for="Space-@DriverInfo.Id">Antall plasser</label>
            <input id="Space-@DriverInfo.Id" type="number" @bind="DriverInfo.AvailableSpace" placeholder="F.eks. 4" style="max-width: 110px;" />
        </div>
    </div>

    <div class="passengers @(DriverInfo.BilenErStappFull ? "full" : "")">
        <div class="passengers-header">
            <h4>Passasjerer</h4>
            <span class="capacity-badge @(DriverInfo.BilenErStappFull ? "full" : "")">
                @DriverInfo.Passengers.Count / @(DriverInfo.AvailableSpace > 0 ? DriverInfo.AvailableSpace.ToString() : "?")
            </span>
        </div>
        @foreach (var passenger in DriverInfo.Passengers)
        {
            <Passenger PassengerInfo="passenger" OnDelete="OnRemovePassenger" />
        }
        <button class="addpassbtn" disabled=@(DriverInfo.BilenErStappFull) @onclick="OnAddPassenger">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Jeg vil sitte på
        </button>
        @if (DriverInfo.BilenErStappFull)
        {
            <p class="buttonDisabledMsg">Beklager, bilen er full!</p>
        }
    </div>
</div>

@code {
    [Parameter]
    public DriverModel DriverInfo { get; set; }

    [Parameter]
    public EventCallback<DriverModel> OnDelete { get; set; }

    public async Task OnAddPassenger()
    {
        var newPassenger = new PassengerModel();
        DriverInfo.Passengers.Add(newPassenger);

        StateHasChanged();
        await Task.Delay(10);

        var inputId = $"passengerName-{newPassenger.Id}";
        await JSRuntime.InvokeVoidAsync("eval", $"document.getElementById('{inputId}')?.focus()");
    }

    public async Task OnRemovePassenger(PassengerModel passenger)
    {
        var passengerName = string.IsNullOrWhiteSpace(passenger.Name) ? "denne passasjeren" : passenger.Name;
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Er du sikker på at du vil fjerne {passengerName}?");

        if (confirmed)
        {
            DriverInfo.Passengers.Remove(passenger);
            StateHasChanged();
        }
    }
}
