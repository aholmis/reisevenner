@page "/event/{eventCode}"
@using Reisevenner.Web.Data
@inject IEventStorage Storage
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<div class="event-container">
    <div class="page-header">
        <h1>@currentEvent.Name</h1>
    </div>

    <div class="card event-info">
        <div class="event-meta">
            <div class="event-meta-item">
                <span class="event-meta-label">Kode</span>
                <div class="event-code-row">
                    <span class="event-code">@eventCode</span>
                    <button @onclick="CopyEventCode" class="copy-btn" title="Kopier kode til utklippstavle">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                        </svg>
                        Kopier
                    </button>
                    @if (copySuccess)
                    {
                        <span class="copy-success">✓ Kopiert!</span>
                    }
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(currentEvent.When))
            {
                <div class="event-meta-item">
                    <span class="event-meta-label">Når</span>
                    <span class="event-meta-value">@currentEvent.When</span>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(currentEvent.Where))
            {
                <div class="event-meta-item">
                    <span class="event-meta-label">Hvor</span>
                    <span class="event-meta-value">@currentEvent.Where</span>
                </div>
            }
        </div>
        <p class="share-hint">💡 Del koden med deltagerne så de kan bli @Constants.AppName!</p>
    </div>

    <div class="drivers-section">
        <div class="drivers-section-header">
            <h2>Sjåfører</h2>
            @if (currentEvent.Drivers.Count > 0)
            {
                <span class="driver-count-badge">@currentEvent.Drivers.Count sjåfør@(currentEvent.Drivers.Count == 1 ? "" : "er")</span>
            }
        </div>

        @foreach (var driver in currentEvent.Drivers)
        {
            <Driver DriverInfo="driver" OnDelete="DeleteDriver" />
        }

        <button @onclick="AddDriver">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Legg til sjåfør
        </button>
    </div>
</div>

@code {
    [Parameter]
    public string eventCode { get; set; }
    EventModel currentEvent;
    bool copySuccess = false;

    protected override void OnParametersSet()
    {
        bool exists = Storage.TryGetValue(eventCode, out var storedEvent);
        if (!exists)
        {
            Navigation.NavigateTo("/notfound", true);
            return;
        }

        currentEvent = storedEvent;
    }

    async Task CopyEventCode()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", eventCode);
            copySuccess = true;
            StateHasChanged();

            await Task.Delay(2000);
            copySuccess = false;
            StateHasChanged();
        }
        catch
        {
            await JSRuntime.InvokeVoidAsync("alert", "Kunne ikke kopiere til utklippstavle. Prøv å velge og kopiere koden manuelt.");
        }
    }

    async Task AddDriver()
    {
        var newDriver = new DriverModel();
        currentEvent.Drivers.Add(newDriver);

        StateHasChanged();
        await Task.Delay(10);

        var inputId = $"Name-{newDriver.Id}";
        await JSRuntime.InvokeVoidAsync("eval", $"document.getElementById('{inputId}')?.focus()");
    }

    void DeleteDriver(DriverModel driver)
    {
        currentEvent.Drivers.Remove(driver);
    }
}
