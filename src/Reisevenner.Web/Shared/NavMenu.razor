@using Reisevenner.Web.Data

<div class="nav-brand-row">
    <div class="nav-brand-inner">
        <span class="nav-brand-icon">🚗</span>
        <a class="nav-brand-name" href="">@Constants.AppName</a>
    </div>
    <button class="nav-toggle" title="Meny" @onclick="ToggleNavMenu" aria-expanded="@(!collapseNavMenu)">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            @if (collapseNavMenu)
            {
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            }
            else
            {
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
            }
        </svg>
    </button>
</div>

<nav class="@(collapseNavMenu ? "nav-links collapsed" : "nav-links")">
    <NavLink class="nav-link-item" href="" Match="NavLinkMatch.All">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
        Hjem
    </NavLink>
    <NavLink class="nav-link-item" href="create-event">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="16"></line>
            <line x1="8" y1="12" x2="16" y2="12"></line>
        </svg>
        Lag oppdrag
    </NavLink>
</nav>

@code {
    private bool collapseNavMenu = true;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
